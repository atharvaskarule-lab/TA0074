<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">

    <uses-permission android:name="android.permission.INTERNET" />

    <application
        android:allowBackup="true"
        android:dataExtractionRules="@xml/data_extraction_rules"
        android:fullBackupContent="@xml/backup_rules"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:supportsRtl="true"
        android:theme="@style/Theme.SHRAMIKCONNECT">
        
        <activity
            android:name=".WorkerProfileActivity"
            android:exported="false" />
        <activity
            android:name=".CustomerDashboardActivity"
            android:exported="false" />
        <activity
            android:name=".WorkerDashboardActivity"
            android:exported="false" /> <!-- Firebase Messaging Service -->
        <service
            android:name=".MyFirebaseMessagingService"
            android:exported="false">
            <intent-filter>
                <action android:name="com.google.firebase.MESSAGING_EVENT" />
            </intent-filter>
        </service> <!-- Activities -->
        <activity
            android:name=".EditProfileActivity"
            android:exported="false" />
        <activity
            android:name=".CustomerJobsActivity"
            android:exported="false" />
        <activity
            android:name=".CustomerHomeActivity"
            android:exported="false" />
        <activity
            android:name=".WorkerJobsActivity"
            android:exported="false" />
        <activity
            android:name=".WorkerHomeActivity"
            android:exported="false" />
        <activity
            android:name=".SignupActivity"
            android:exported="false" /> <!-- ✅ Login is Launcher Activity -->
        <activity
            android:name=".LoginActivity"
            android:exported="true">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />

                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>
    </application>

</manifest>
