<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:background="#F4F6F9"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <LinearLayout
        android:orientation="vertical"
        android:padding="24dp"
        android:layout_width="match_parent"
        android:layout_height="wrap_content">

        <!-- Welcome -->
        <TextView
            android:id="@+id/tvWelcome"
            android:text="Welcome, Worker"
            android:textSize="22sp"
            android:textStyle="bold"
            android:textColor="#1E3A8A"
            android:layout_marginBottom="16dp"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"/>

        <!-- Rating -->
        <TextView
            android:id="@+id/tvRating"
            android:text="Rating: 0.0 ⭐"
            android:textSize="16sp"
            android:layout_marginBottom="8dp"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"/>

        <!-- Earnings -->
        <TextView
            android:id="@+id/tvEarnings"
            android:text="Total Earnings: ₹0"
            android:textSize="16sp"
            android:layout_marginBottom="16dp"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"/>

        <!-- Availability Switch -->
        <LinearLayout
            android:orientation="horizontal"
            android:layout_marginBottom="24dp"
            android:layout_width="match_parent"
            android:layout_height="wrap_content">

            <TextView
                android:text="Available"
                android:textSize="16sp"
                android:layout_weight="1"
                android:layout_width="0dp"
                android:layout_height="wrap_content"/>

            <Switch
                android:id="@+id/switchAvailability"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"/>
        </LinearLayout>

        <!-- Buttons -->

        <Button
            android:id="@+id/btnViewJobs"
            android:text="View Job Requests"
            android:backgroundTint="#1E3A8A"
            android:textColor="@android:color/white"
            android:layout_marginBottom="12dp"
            android:layout_width="match_parent"
            android:layout_height="50dp"/>

        <Button
            android:id="@+id/btnEditProfile"
            android:text="Edit Profile"
            android:backgroundTint="#4CAF50"
            android:textColor="@android:color/white"
            android:layout_marginBottom="12dp"
            android:layout_width="match_parent"
            android:layout_height="50dp"/>

        <Button
            android:id="@+id/btnLogout"
            android:text="Logout"
            android:backgroundTint="#E53935"
            android:textColor="@android:color/white"
            android:layout_width="match_parent"
            android:layout_height="50dp"/>

    </LinearLayout>
</ScrollView>